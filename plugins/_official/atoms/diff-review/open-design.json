{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "name": "diff-review",
  "title": "Diff review",
  "version": "0.1.0",
  "description": "Surface the accumulated patch as a reviewable diff and persist the accept / reject decision.",
  "license": "MIT",
  "tags": ["atom", "first-party", "code-migration", "tune-collab", "phase-7"],
  "compat": { "agentSkills": [{ "path": "./SKILL.md" }] },
  "od": {
    "kind": "atom",
    "scenario": "code-migration",
    "mode": "review",
    "capabilities": ["prompt:inject", "fs:read", "fs:write"]
  }
}
